# ============================================================
#  Research NotebookLM — Environment Config
#  Copy this file to .env and fill in your values.
#  The app works without any API keys using local Ollama.
# ============================================================

# Optional: secret key for session signing (auto-generated if not set)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# FLASK_SECRET_KEY=your-random-secret-here

# Optional: port (default: 8080)
# WEBAPP_PORT=8080

# Optional: host binding (default: 127.0.0.1 = localhost only)
# Set to 0.0.0.0 ONLY if using a reverse proxy (Caddy, nginx, etc.)
# WEBAPP_HOST=127.0.0.1

# Optional: allowed CORS origins (comma-separated, default: localhost only)
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional: default Ollama model if no providers are configured
# OLLAMA_MODEL=qwen2.5:3b
